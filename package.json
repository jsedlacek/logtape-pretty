{
  "name": "@jsedlacek/logtape-pretty",
  "version": "0.6.0",
  "description": "Pretty formatter for LogTape",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "demo": "node --experimental-strip-types examples/logtape.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "release": "node --experimental-strip-types scripts/release.ts",
    "release:minor": "node --experimental-strip-types scripts/release.ts minor",
    "release:major": "node --experimental-strip-types scripts/release.ts major",
    "generate-svg": "node --experimental-strip-types scripts/generate-svg.ts"
  },
  "keywords": [
    "logtape",
    "formatter",
    "pretty",
    "pino-pretty",
    "logging"
  ],
  "license": "MIT",
  "author": "Jakub Sedlacek",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsedlacek/logtape-pretty"
  },
  "devDependencies": {
    "@logtape/logtape": "^2.0.4",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
